# FastPay Connect — Пример конфигурации
# Скопируйте этот файл в .env и заполните реальными значениями

# ============================================
# API ключи для платёжных систем
# ============================================
YOOKASSA_API_KEY=your_yookassa_api_key
TINKOFF_API_KEY=your_tinkoff_api_key
CLOUDPAYMENTS_API_KEY=your_cloudpayments_api_key
UNITPAY_API_KEY=your_unitpay_api_key
ROBOKASSA_API_KEY=your_robokassa_api_key

# ============================================
# Секретные ключи для подписи запросов
# ============================================
YOOKASSA_SECRET_KEY=your_yookassa_secret_key
TINKOFF_SECRET_KEY=your_tinkoff_secret_key
CLOUDPAYMENTS_SECRET_KEY=your_cloudpayments_secret_key
UNITPAY_SECRET_KEY=your_unitpay_secret_key
ROBOKASSA_SECRET_KEY=your_robokassa_secret_key

# ============================================
# URL возврата после оплаты
# ============================================
YOOKASSA_RETURN_URL=https://localhost:8080/payment/return
TINKOFF_RETURN_URL=https://localhost:8080/payment/return
CLOUDPAYMENTS_RETURN_URL=https://localhost:8080/payment/return
UNITPAY_RETURN_URL=https://localhost:8080/payment/return
ROBOKASSA_RETURN_URL=https://localhost:8080/payment/return

# ============================================
# База данных
# ============================================
# SQLite для локальной разработки
DATABASE_URL=sqlite:///./fastpay_connect.db
# PostgreSQL для продакшена (раскомментируйте и заполните)
# DATABASE_URL=postgresql://user:password@localhost:5432/fastpay_db

# ============================================
# Настройки приложения
# ============================================
SECRET_KEY=your_secret_key_for_sessions_and_tokens
ALLOWED_HOSTS=localhost,127.0.0.1
ALLOWED_ORIGINS=http://localhost,https://localhost
DEBUG=True

# ============================================
# IP адреса платёжных систем для webhook
# ============================================
YOOKASSA_IPS=77.75.153.0/24,77.75.156.0/24,77.75.157.0/24,77.75.158.0/24
TINKOFF_IPS=185.215.82.0/24
CLOUDPAYMENTS_IPS=95.163.0.0/16
UNITPAY_IPS=109.207.0.0/16
ROBOKASSA_IPS=31.131.248.0/24

# ============================================
# Почтовый сервис (для уведомлений)
# ============================================
MAIL_USERNAME=your_mail_username
MAIL_PASSWORD=your_mail_password
MAIL_SERVER=smtp.mailtrap.io
MAIL_PORT=587

# ============================================
# Сервер
# ============================================
HOST=127.0.0.1
PORT=8080
ENV=development

# ============================================
# Логирование
# ============================================
LOG_LEVEL=INFO
