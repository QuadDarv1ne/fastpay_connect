# AWS Elastic Beanstalk Configuration
# Документация: https://docs.aws.amazon.com/elasticbeanstalk/latest/dg/create_deploy_python.html

BranchDefault: true
EnvironmentName: fastpay-connect-production
Platform:
  PlatformName: Python
  PlatformVersion: 3.11
OptionSettings:
  aws:elasticbeanstalk:environment:proxy:staticfiles:
    /static: "app/static"
  aws:elasticbeanstalk:application:environment:
    PYTHON_VERSION: "3.11"
    ENV: "production"
    LOG_LEVEL: "INFO"
    PORT: "8080"
  aws:elasticbeanstalk:container:python:
    WSGIPath: app.main:app
    NumProcesses: 2
    NumThreads: 10
  aws:elasticbeanstalk:environment:proxy:staticfiles:
    StaticFiles: "app/static"
  aws:elasticbeanstalk:command:
    CommandTimeout: 60
    BatchSize: 30
    BatchSizeType: Fixed
  aws:autoscaling:asg:
    MinSize: 1
    MaxSize: 4
    Availability Zones: Any
  aws:autoscaling:trigger:
    MeasureName: NetworkTransmitBytesPerSecond
    Statistic: Average
    Unit: Bytes
    LowerThreshold: 100000
    UpperThreshold: 100000000
    Period: 5
    EvaluationPeriods: 1
    BreachDuration: 5
